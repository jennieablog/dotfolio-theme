---
layout: null
---
[
  {% for post in site.posts %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "excerpt": {{ post.excerpt | strip_html | strip_newlines | jsonify }},
      "date": "{{ post.date | date: "%B %-d, %Y" }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]